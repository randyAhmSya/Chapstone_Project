# SUPABASE DATABASE

# Pakai untuk: semua query Prisma saat runtime (port 6543 = connection pooling)
DATABASE_URL="postgresql://postgres.[PROJECT-REF]:[DB-PASSWORD]@aws-0-ap-southeast-1.pooler.supabase.com:6543/postgres?pgbouncer=true"

# Pakai untuk: prisma db push / prisma migrate (port 5432 = direct connection)
DIRECT_URL="postgresql://postgres.[PROJECT-REF]:[DB-PASSWORD]@aws-0-ap-southeast-1.pooler.supabase.com:5432/postgres"

# SUPABASE API — untuk Supabase Storage (upload file CV)
# Ambil dari: Supabase Dashboard → Settings → API
SUPABASE_URL="https://[PROJECT-REF].supabase.co"
SUPABASE_SERVICE_ROLE_KEY="eyJ..."   # gunakan service_role key (bukan anon key)

# APP CONFIG
PORT=3001
NODE_ENV=development

# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=""
JWT_EXPIRES_IN="7d"

# URL frontend React (untuk CORS)
CLIENT_URL="http://localhost:5173"

# URL AI Service FastAPI — dikerjakan AI Engineer
AI_SERVICE_URL="HTTP://LOCALHOST:8000"
